{
  "name": "@cdot/event_calendar",
  "description": "Event Calendar",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "module": "dist/mjs/index.js",
  "exports": {
    "import": "./dist/mjs/index.js",
    "require": "./dist/cjs/index.js"
  },
  "author": {
    "name": "Crawford Currie",
    "url": "https://github.com/cdot"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/cdot/EventCalendar"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "README.md",
    "dist/*/*.js",
    "src/*.js",
    "html/*.html",
    "css/*.css"
  ],
  "scripts": {
    "build": "webpack -c webpack/cjs.js & webpack -c webpack/mjs.js & webpack -c webpack/amd.js",
    "lint": "eslint src -f unix",
    "doc": "jsdoc -c jsdoc_config.json src/*.js README.md"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "docdash": "^2.0.2",
    "eslint": "^10.0.3",
    "eslint-formatter-unix": "^9.0.1",
    "globals": "^17.4.0",
    "jsdoc": "^4.0.5",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1"
  }
}
